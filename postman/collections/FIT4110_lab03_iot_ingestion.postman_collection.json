    {
      "name": "02_Auth",
      "item": [
        {
          "name": "GET /devices/{deviceId}/latest - valid token is accepted",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/devices/SENSOR-001/latest",

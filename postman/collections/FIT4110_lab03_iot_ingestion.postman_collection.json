{
  "info": {
    "_postman_id": "fit4110-lab03-iot-ingestion-contract-tests",
    "name": "FIT4110 Lab03 - IoT Ingestion Contract Tests",
    "description": "Contract tests cho service IoT Ingestion, đồng bộ với OpenAPI Lab 02 của nhóm 8. Collection chạy được trên Prism mock và có thể dùng lại cho local service.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const prefix = pm.environment.get('tracePrefix') || 'fit4110-lab03-iot';",
          "pm.variables.set('traceId', prefix + '-' + Date.now());",
          "pm.request.headers.upsert({ key: 'X-Trace-Id', value: pm.variables.get('traceId') });"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "01_Functional",
      "item": [
        {
          "name": "GET /health - service is alive",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Health response has ok status and service name', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('status', 'ok');",
                  "  pm.expect(json).to.have.property('service', 'iot-ingestion');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /telemetry/readings - happy path accepts reading",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/telemetry/readings",
              "host": ["{{baseUrl}}"],
              "path": ["telemetry", "readings"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"deviceId\": \"SENSOR-001\",\n  \"locationId\": \"ROOM-A101\",\n  \"sensorType\": \"temperature\",\n  \"value\": 30.5,\n  \"unit\": \"celsius\",\n  \"timestamp\": \"2026-05-19T04:33:00Z\",\n  \"correlationId\": \"0196fb3d-4ad7-7d1e-9f49-5d5148d2babc\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 202 Accepted', function () { pm.response.to.have.status(202); });",
                  "pm.test('Response has accepted reading fields', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('readingId');",
                  "  pm.expect(json).to.have.property('eventId');",
                  "  pm.expect(json).to.have.property('status', 'ACCEPTED');",
                  "  pm.expect(json).to.have.property('acceptedAt');",
                  "});",
                  "pm.test('Identifiers are UUID-like', function () {",
                  "  const json = pm.response.json();",
                  "  const uuidPattern = /^[0-9a-fA-F-]{36}$/;",
                  "  pm.expect(json.readingId).to.match(uuidPattern);",
                  "  pm.expect(json.eventId).to.match(uuidPattern);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /telemetry/readings/{readingId} - get accepted reading",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/telemetry/readings/0196fb3d-4ad7-7d1e-9f49-5d5148d2b111",
              "host": ["{{baseUrl}}"],
              "path": ["telemetry", "readings", "0196fb3d-4ad7-7d1e-9f49-5d5148d2b111"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response contains normalized telemetry reading', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('readingId');",
                  "  pm.expect(json).to.have.property('deviceId');",
                  "  pm.expect(json).to.have.property('sensorType');",
                  "  pm.expect(json).to.have.property('ingestedAt');",
                  "});"

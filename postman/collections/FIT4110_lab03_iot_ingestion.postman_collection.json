              "path": ["devices", "SENSOR-001", "latest"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Valid token request returns success', function () {",
                  "  pm.expect(pm.response.code).to.eql(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /telemetry/readings - missing token is rejected on real service",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/telemetry/readings",
              "host": ["{{baseUrl}}"],
              "path": ["telemetry", "readings"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"deviceId\": \"SENSOR-001\",\n  \"locationId\": \"ROOM-A101\",\n  \"sensorType\": \"temperature\",\n  \"value\": 30.5,\n  \"unit\": \"celsius\",\n  \"timestamp\": \"2026-05-19T04:33:00Z\",\n  \"correlationId\": \"0196fb3d-4ad7-7d1e-9f49-5d5148d2babc\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const env = pm.environment.get('env') || 'mock';",
                  "if (env === 'mock') {",
                  "  pm.test('Skipped on mock: Prism does not enforce real auth middleware', function () { pm.expect(true).to.eql(true); });",
                  "} else {",
                  "  pm.test('Missing token returns 401 or 403', function () { pm.expect([401, 403]).to.include(pm.response.code); });",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /telemetry/readings - invalid token is rejected on real service",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer invalid-token" }
            ],
            "url": {
              "raw": "{{baseUrl}}/telemetry/readings",
              "host": ["{{baseUrl}}"],
              "path": ["telemetry", "readings"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"deviceId\": \"SENSOR-001\",\n  \"locationId\": \"ROOM-A101\",\n  \"sensorType\": \"temperature\",\n  \"value\": 30.5,\n  \"unit\": \"celsius\",\n  \"timestamp\": \"2026-05-19T04:33:00Z\",\n  \"correlationId\": \"0196fb3d-4ad7-7d1e-9f49-5d5148d2babc\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const env = pm.environment.get('env') || 'mock';",
                  "if (env === 'mock') {",
                  "  pm.test('Skipped on mock: invalid token requires real auth middleware', function () { pm.expect(true).to.eql(true); });",
                  "} else {",
                  "  pm.test('Invalid token returns 401 or 403', function () { pm.expect([401, 403]).to.include(pm.response.code); });",
                  "}"
                ]
              }
            }
          ]
        }
      ]

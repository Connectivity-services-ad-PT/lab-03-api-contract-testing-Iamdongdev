    {
      "name": "06_Local_only_NonFunctional",
      "item": [
        {
          "name": "POST /telemetry/readings - local response time threshold",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/telemetry/readings",
              "host": ["{{baseUrl}}"],
              "path": ["telemetry", "readings"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"deviceId\": \"SENSOR-002\",\n  \"locationId\": \"ROOM-A102\",\n  \"sensorType\": \"humidity\",\n  \"value\": 55.2,\n  \"unit\": \"percent\",\n  \"timestamp\": \"2026-05-19T04:35:00Z\",\n  \"correlationId\": \"0196fb3d-4ad7-7d1e-9f49-5d5148d2bdef\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const env = pm.environment.get('env') || 'mock';",
                  "if (env === 'local') {",
                  "  pm.test('Local service responds under 1000ms', function () { pm.expect(pm.response.responseTime).to.be.below(1000); });",
                  "} else {",
                  "  pm.test('Skipped on mock: mock latency is not evidence of real service reliability', function () { pm.expect(true).to.eql(true); });",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
